# Copy to `.env` and adjust. Used by docker-compose.yml.

# Host directory with input models; *_neutron.tflite outputs are written here.
# Mounted at /data inside the container (the CLI's working dir).
MODELS_DIR=./models

# Host directory of the extracted eIQ Neutron SDK (run scripts/setup_sdk.sh).
# Mounted read-only at /opt/sdk; enables the nxp quantization backend.
# Leave as-is if you provisioned the SDK under vendor/ in this repo.
NEUTRON_SDK_DIR=./vendor/eiq-neutron-sdk
